# GazQueue — Required Environment Variables for Vercel Deployment
#
# These must be set in the Vercel project dashboard:
# https://vercel.com/[project-name]/settings/environment-variables

# Upstash Redis REST API (required for API serverless functions)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Telegram Bot Token (required for Telegram notifications)
# Get this from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-bot-token

# Bot username (optional, defaults to GazQueueBot)
# BOT_USERNAME=GazQueueBot
